{
    "name": "frkn-vpn-bot",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "engines": {
        "node": "24.x"
    },
    "scripts": {
        "postinstall": "prisma generate",
        "start": "node --loader ts-node/esm src/index.ts",
        "dev": "nodemon --exec node --loader ts-node/esm src/index.ts",
        "build": "tsc",
        "test:types": "tsc --noEmit",
        "test:lint": "biome check . --diagnostic-level=error"
    },
    "devDependencies": {
        "@biomejs/biome": "2.2.4",
        "@types/node": "^22.0.0",
        "@types/qrcode": "1.5.5",
        "nodemon": "3.1.10",
        "prisma": "6.13.0",
        "ts-node": "10.9.2",
        "tsx": "4.21.0",
        "typescript": "5.8.3"
    },
    "dependencies": {
        "@grammyjs/conversations": "^1.2.0",
        "@prisma/client": "6.13.0",
        "axios": "1.10.0",
        "dotenv": "16.5.0",
        "grammy": "^1.30.0",
        "js-sha3": "0.9.3",
        "qrcode": "1.5.4"
    }
}
